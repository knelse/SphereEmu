<Window x:Class="PacketLogViewer.Dialogs.TrackXpDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Track XP"
        Width="520"
        Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold">Title Level</TextBlock>
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TitleLevelTextBox" Margin="8 4 0 4" />

            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold">Title Rebirth</TextBlock>
            <ComboBox Grid.Row="1" Grid.Column="1" x:Name="TitleRebirthComboBox" Margin="8 4 0 4" />

            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold">Title XP</TextBlock>
            <TextBox Grid.Row="2" Grid.Column="1" x:Name="TitleXpTextBox" Margin="8 4 0 4" />

            <Separator Grid.Row="3" Grid.ColumnSpan="2" Margin="0 8" />

            <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold">Degree Level</TextBlock>
            <TextBox Grid.Row="4" Grid.Column="1" x:Name="DegreeLevelTextBox" Margin="8 4 0 4" />

            <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold">Degree Rebirth</TextBlock>
            <ComboBox Grid.Row="5" Grid.Column="1" x:Name="DegreeRebirthComboBox" Margin="8 4 0 4" />

            <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold">Degree XP</TextBlock>
            <TextBox Grid.Row="6" Grid.Column="1" x:Name="DegreeXpTextBox" Margin="8 4 0 4" />

            <Separator Grid.Row="7" Grid.ColumnSpan="2" Margin="0 8" />

            <TextBlock Grid.Row="8" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold">Pill Active</TextBlock>
            <CheckBox Grid.Row="8" Grid.Column="1" x:Name="PillActiveCheckBox" Margin="8 6 0 6" />

            <TextBlock Grid.Row="9" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold">Server Bonus</TextBlock>
            <ComboBox Grid.Row="9" Grid.Column="1" x:Name="ServerBonusComboBox" Margin="8 4 0 4" />

            <TextBlock Grid.Row="10" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold">Area For Missions</TextBlock>
            <ComboBox Grid.Row="10" Grid.Column="1" x:Name="MissionAreaComboBox" Margin="8 4 0 4" />
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 12 0 0">
            <Button Width="110" Margin="0 0 8 0" IsCancel="True">Cancel</Button>
            <Button Width="110" IsDefault="True" Click="Ok_OnClick">OK</Button>
        </StackPanel>
    </Grid>
</Window>

