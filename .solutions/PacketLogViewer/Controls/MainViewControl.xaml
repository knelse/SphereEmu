<UserControl x:Class="PacketLogViewer.Controls.MainViewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:PacketLogViewer.Controls"
             xmlns:local="clr-namespace:PacketLogViewer"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="7*" />
            <RowDefinition Height="3*" MaxHeight="220" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="500" />
            <ColumnDefinition Width="*" MinWidth="400" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="750" MinWidth="200" />
        </Grid.ColumnDefinitions>

        <controls:FilterTogglesControl x:Name="FilterToggles" x:FieldModifier="public" Grid.Row="0" Grid.Column="0"
                                       Grid.ColumnSpan="4" />

        <GridSplitter Grid.Row="1" Grid.Column="0" Grid.RowSpan="2" Width="8" Background="White"
                      ResizeBehavior="CurrentAndNext"
                      Margin="10 4 0 4 " />

        <controls:PacketLogListControl x:Name="PacketLogList" x:FieldModifier="public" Grid.Row="1" Margin="4"
                                       Grid.Column="0" />

        <controls:GameStateControl x:Name="GameState" x:FieldModifier="public" Grid.Row="2" Grid.Column="0"
                                  Margin="4 0" />

        <GridSplitter Grid.Row="0" Grid.RowSpan="3" Grid.Column="2" Width="5" HorizontalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext" Background="White" Margin="0 4" />

        <local:EntityRadarControl x:Name="EntityRadar" x:FieldModifier="public" Grid.Row="0" Grid.RowSpan="3"
                                  Grid.Column="3" />

        <Grid Grid.Row="0" Grid.RowSpan="3" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="5*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <controls:PacketActionsBarControl x:Name="PacketActionsBar" x:FieldModifier="public" Grid.Row="0" />

            <controls:PacketVisualizerPanelControl x:Name="PacketVisualizerPanel" x:FieldModifier="public"
                                                  Grid.Row="1" />

            <controls:ClientStatePanelControl x:Name="ClientStatePanel" x:FieldModifier="public" Grid.Row="2" />
        </Grid>
    </Grid>
</UserControl>

