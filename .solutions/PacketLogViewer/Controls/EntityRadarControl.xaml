<UserControl x:Class="PacketLogViewer.EntityRadarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="750" MinHeight="750"
             ToolTipService.InitialShowDelay="0"
             ToolTipService.BetweenShowDelay="0">
    <Border BorderBrush="#444" BorderThickness="1" Background="#0d1117">
        <Grid>
            <!-- Rings + client marker: no hit-test so tooltips stay on entity shapes -->
            <Canvas x:Name="RingsCanvas" ClipToBounds="True" IsHitTestVisible="False" />
            <Canvas x:Name="EntitiesCanvas" ClipToBounds="True" />
            <TextBlock x:Name="PlaceholderText"
                       Text="Waiting for client position (ping)…"
                       Foreground="#8b949e"
                       FontFamily="Hack"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"
                       Margin="8" />
        </Grid>
    </Border>
</UserControl>
