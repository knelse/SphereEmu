<UserControl x:Class="PacketLogViewer.Controls.DefinitionsPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="300" />
            <RowDefinition Height="4" />
            <RowDefinition Height="45" />
            <RowDefinition Height="30" />
            <RowDefinition Height="300" />
            <RowDefinition Height="4" />
            <RowDefinition Height="45" />
            <RowDefinition Height="30" />
            <RowDefinition Height="300" />
            <RowDefinition Height="4" />
            <RowDefinition Height="45" />
            <RowDefinition Height="45" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Label HorizontalAlignment="Stretch"
               HorizontalContentAlignment="Center"
               Background="LightSalmon"
               VerticalAlignment="Stretch"
               VerticalContentAlignment="Center"
               BorderBrush="Black"
               Margin="0 4"
               Padding="0"
               BorderThickness="0.5"
               FontWeight="Bold">
            Existing packet definitions
        </Label>

        <ListBox Grid.Row="1"
                 x:Name="DefinedPacketsListBox"
                 x:FieldModifier="public"
                 SelectionMode="Single"
                 ItemContainerStyle="{StaticResource PacketsListStyle}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <GridSplitter Grid.Row="2"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Rows"
                      Height="4"
                      Padding="0"
                      HorizontalAlignment="Stretch" />

        <Grid Grid.Row="3" HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="50" />
            </Grid.ColumnDefinitions>

            <Button x:Name="SavePacketDefinitionButton"
                    x:FieldModifier="public"
                    Grid.Column="0"
                    Width="40"
                    Margin="5 0"
                    Height="30"
                    FontWeight="Bold"
                    FontSize="24"
                    VerticalContentAlignment="Center"
                    Padding="0">
                🖫
            </Button>
            <Button x:Name="CreateNewPacketDefinitionButton"
                    x:FieldModifier="public"
                    Grid.Column="1"
                    Width="40"
                    Margin="5 0"
                    Height="30"
                    FontWeight="Bold"
                    FontSize="16">
                ➕
            </Button>
            <Button x:Name="DeletePacketDefinitionButton"
                    x:FieldModifier="public"
                    Grid.Column="2"
                    Width="40"
                    Margin="5 0"
                    Height="30"
                    FontWeight="Bold"
                    FontSize="16">
                ➖
            </Button>
        </Grid>

        <Label Grid.Row="4"
               HorizontalAlignment="Stretch"
               HorizontalContentAlignment="Center"
               Background="LightSalmon"
               VerticalAlignment="Stretch"
               VerticalContentAlignment="Center"
               BorderBrush="Black"
               Margin="0 4"
               Padding="0"
               BorderThickness="0.5"
               FontWeight="Bold">
            Packet parts in definition
        </Label>

        <ListBox Grid.Row="5"
                 x:Name="PacketPartsInDefinitionListBox"
                 x:FieldModifier="public"
                 SelectionMode="Extended"
                 ItemContainerStyle="{StaticResource PacketsListStyle}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding PartListDisplayText}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <GridSplitter Grid.Row="6"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Rows"
                      Height="4"
                      Padding="0"
                      HorizontalAlignment="Stretch" />

        <Grid Grid.Row="7" HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="50" />
            </Grid.ColumnDefinitions>

            <Button x:Name="EditPacketPartButton"
                    x:FieldModifier="public"
                    Grid.Column="0"
                    Margin="5 0"
                    Width="40"
                    Height="30"
                    FontWeight="Bold"
                    FontSize="24"
                    VerticalContentAlignment="Center"
                    Padding="0">
                🖉
            </Button>
            <Button x:Name="DeletePacketPartButton"
                    x:FieldModifier="public"
                    Grid.Column="1"
                    Width="40"
                    Margin="5 0"
                    Height="30"
                    FontWeight="Bold"
                    FontSize="16">
                ➖
            </Button>
        </Grid>

        <Label Grid.Row="8"
               HorizontalAlignment="Stretch"
               HorizontalContentAlignment="Center"
               Background="LightSalmon"
               VerticalAlignment="Stretch"
               VerticalContentAlignment="Center"
               BorderBrush="Black"
               Margin="0 4"
               Padding="0"
               BorderThickness="0.5"
               FontWeight="Bold">
            Existing subpackets
        </Label>

        <ListBox Grid.Row="9"
                 x:Name="SubpacketsListBox"
                 x:FieldModifier="public"
                 SelectionMode="Single"
                 ItemContainerStyle="{StaticResource PacketsListStyle}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <GridSplitter Grid.Row="10"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Rows"
                      Height="4"
                      Padding="0"
                      HorizontalAlignment="Stretch" />

        <Grid Grid.Row="11" HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="50" />
            </Grid.ColumnDefinitions>

            <Button x:Name="ImportFromSubpacketButton"
                    x:FieldModifier="public"
                    Grid.Column="0"
                    Margin="5 0"
                    Width="40"
                    Height="30"
                    FontWeight="Bold"
                    FontSize="24"
                    VerticalContentAlignment="Center"
                    Padding="0">
                🧱
            </Button>
            <Button x:Name="ExportSubpacketButton"
                    x:FieldModifier="public"
                    Grid.Column="1"
                    Width="40"
                    Margin="5 0"
                    Height="30"
                    FontWeight="Bold"
                    FontSize="16">
                ➕
            </Button>
        </Grid>
    </Grid>
</UserControl>

