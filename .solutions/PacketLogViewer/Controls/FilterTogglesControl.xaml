<UserControl x:Class="PacketLogViewer.Controls.FilterTogglesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <!-- WrapPanel keeps the top toggles visible on smaller window sizes by allowing wrapping -->
    <WrapPanel VerticalAlignment="Center" Margin="2 2 2 2">
        <CheckBox x:Name="ShowBookmarkedOnly"
                  x:FieldModifier="public"
                  Margin="0 2 12 2"
                  Background="White"
                  VerticalAlignment="Center"
                  IsChecked="False">
            Bookmarked Only
        </CheckBox>

        <CheckBox x:Name="HideClientPackets"
                  x:FieldModifier="public"
                  Margin="0 2 12 2"
                  Background="White"
                  VerticalAlignment="Center"
                  IsChecked="True">
            Hide client
        </CheckBox>

        <CheckBox x:Name="HideServerJunk"
                  x:FieldModifier="public"
                  Margin="0 2 12 2"
                  Background="White"
                  VerticalAlignment="Center"
                  IsChecked="True">
            Hide junk
        </CheckBox>

        <CheckBox x:Name="ShowNewInUi"
                  x:FieldModifier="public"
                  Margin="0 2 12 2"
                  Background="White"
                  VerticalAlignment="Center"
                  IsChecked="True">
            Update UI
        </CheckBox>

        <CheckBox x:Name="EnableListener"
                  x:FieldModifier="public"
                  Margin="0 2 12 2"
                  Background="White"
                  VerticalAlignment="Center"
                  IsChecked="True">
            Listener
        </CheckBox>
    </WrapPanel>
</UserControl>
