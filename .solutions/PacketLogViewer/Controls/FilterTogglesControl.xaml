<UserControl x:Class="PacketLogViewer.Controls.FilterTogglesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <CheckBox x:Name="ShowBookmarkedOnly"
                  x:FieldModifier="public"
                  Grid.Column="0"
                  Margin="2 4 4 2"
                  Background="White"
                  VerticalAlignment="Center"
                  IsChecked="False"
                  HorizontalAlignment="Left">
            Bookmarked Only
        </CheckBox>

        <CheckBox x:Name="HideJunk"
                  x:FieldModifier="public"
                  Grid.Column="1"
                  Margin="2 4 4 2"
                  Background="White"
                  VerticalAlignment="Center"
                  IsChecked="True"
                  HorizontalAlignment="Left">
            Hide junk
        </CheckBox>

        <CheckBox x:Name="EnableListener"
                  x:FieldModifier="public"
                  Grid.Column="2"
                  Margin="2 4 4 2"
                  Background="White"
                  VerticalAlignment="Center"
                  IsChecked="True"
                  HorizontalAlignment="Left">
            Enable Listener
        </CheckBox>

        <CheckBox x:Name="ShowNewInUi"
                  x:FieldModifier="public"
                  Grid.Column="3"
                  Margin="2 4 4 2"
                  Background="White"
                  VerticalAlignment="Center"
                  IsChecked="True"
                  HorizontalAlignment="Left">
            Show new in UI
        </CheckBox>
    </Grid>
</UserControl>
